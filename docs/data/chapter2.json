      "id": "2.grammar",
      "type": "short_answer",
      "title": "Grammar facts",
      "questions": [
        {
          "question": "How many grammatical genders does Polish have?",
          "answer": "3",
          "note": "masculine (męski), feminine (żeński), neuter (nijaki)"
        },
        {
          "question": "What ending do most feminine nouns have in Polish?",
          "answer": "-a",
          "note": "e.g. kanapa, historia, przyjaciółka"
        },
        {
          "question": "What ending do most neuter nouns have in Polish?",
          "answer": "-o or -e",
          "note": "e.g. uczucie, masło, siodło"
        },
        {
          "question": "Which pronoun is used for an all-female group in Polish?",
          "answer": "one"
        },
        {
          "question": "Which pronoun is used for a mixed or all-male group in Polish?",
          "answer": "oni"
        },
        {
          "question": "Is 'ja' (I) capitalised in Polish?",
          "answer": "no",
          "note": "Unlike English 'I', Polish 'ja' is always lowercase"
