  "exercises": [
    {
      "id": "2.3",
      "type": "fill_in_the_blank",
      "title": "Pronoun equations",
      "questions": [
        {
          "question": "ja + ty = ___  (I + you = ?)",
          "answer": "my",
          "note": "I + you (singular) = we"
        },
        {
          "question": "on + ona = ___  (he + she = ?)",
          "answer": "oni",
          "note": "A mixed male/female group uses oni"
        },
        {
          "question": "ono + ja = ___  (it + I = ?)",
          "answer": "my",
          "note": "Any group including the speaker = my (we)"
        },
        {
          "question": "ona × 2 = ___  (she × 2 = ?)",
          "answer": "one",
          "note": "An all-female group uses one"
        },
        {
          "question": "ono + on + one = ___  (it + he + they[f] = ?)",
          "answer": "oni",
          "note": "A group containing a male subject uses oni"
        },
        {
          "question": "ty × 3 = ___  (you [sg] × 3 = ?)",
          "answer": "wy",
          "note": "Multiple 'you' (singular) = wy (you plural)"
        },
        {
          "question": "wy + ja = ___  (you[pl] + I = ?)",
          "answer": "my",
          "note": "Any group including the speaker = my (we)"
        }
      ]
    },
    {
      "id": "2.4",
      "type": "multiple_choice",
      "title": "Choose the correct pronoun",
      "questions": [
        {
          "question": "___ potrzebują dużo wody. (the roses — they are feminine)",
          "options": ["oni", "one", "my", "wy"],
          "answer": "one",
          "note": "An all-feminine/neutral group uses 'one'"
        },
        {
          "question": "___ ogląda telewizję. (Adam — he)",
          "options": ["on", "ona", "ono", "oni"],
          "answer": "on",
          "note": "A single male subject = on (he)"
        },
        {
          "question": "___ jest fioletowa. (dress — feminine noun)",
          "options": ["on", "ona", "ono", "one"],
          "answer": "ona",
          "note": "Feminine nouns use 'ona' (she/it)"
        },
        {
          "question": "___ idziemy na spacer. (my brother and I)",
          "options": ["my", "wy", "oni", "one"],
          "answer": "my",
          "note": "Speaker + someone else = my (we)"
        },
        {
          "question": "___ nie ma samochodu. (my aunt — female)",
          "options": ["on", "ona", "ono", "one"],
          "answer": "ona",
          "note": "A single female subject = ona (she)"
        },
        {
          "question": "___ płacze. (the child — neuter noun)",
          "options": ["on", "ona", "ono", "one"],
          "answer": "ono",
          "note": "Neuter nouns use 'ono' (it)"
        },
        {
          "question": "Czy ___ jesteście zmęczeni? (you — plural)",
          "options": ["ty", "wy", "oni", "my"],
          "answer": "wy",
          "note": "Plural 'you' = wy"
        }
      ]
    },
