      "title": "Verb moods — indicative, imperative, conditional",
      "questions": [
        {
          "question": "Which mood is used for commands and requests?",
          "options": ["indicative", "conditional", "imperative", "subjunctive"],
          "answer": "imperative"
        },
        {
          "question": "What is the imperative 'ty' form of 'pisać' (to write)?",
          "options": ["piszmy", "piszcie", "pisz", "piszę"],
          "answer": "pisz"
        },
        {
          "question": "What is the imperative 'my' form of 'czytać' (to read)?",
          "options": ["czytaj", "czytajcie", "czytamy", "czytajmy"],
          "answer": "czytajmy"
        },
        {
          "question": "Which mood expresses a proposition dependent on a condition?",
          "options": ["indicative", "conditional", "imperative", "infinitive"],
          "answer": "conditional"
        },
        {
          "question": "What is the conditional 'ja' (masculine) form of 'czytać'?",
          "options": ["czytam", "czytaj", "czytałbym", "czytałabym"],
          "answer": "czytałbym"
        }
      ]
    },
