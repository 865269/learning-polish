  "exercises": [
    {
      "id": "5.1",
      "type": "multiple_choice",
      "title": "Getting directions",
      "questions": [
        {
          "question": "What polite word should you start with when asking a stranger for directions?",
          "options": ["Dziękuję", "Przepraszam", "Proszę", "Cześć"],
          "answer": "Przepraszam"
        },
        {
          "question": "What does 'Gdzie jest...?' mean?",
          "options": ["Is it far?", "Which way to...?", "Where is the...?", "I'm looking for..."],
          "answer": "Where is the...?"
        },
        {
          "question": "How do you say 'straight ahead'?",
          "options": ["w prawo", "w lewo", "cofnąć się", "prosto"],
          "answer": "prosto"
        },
        {
          "question": "What does 'Szukam...' mean?",
          "options": ["Where is...?", "Is it far?", "I'm looking for...", "Which way to...?"],
          "answer": "I'm looking for..."
        },
        {
          "question": "What is 'galeria handlowa'?",
          "options": ["museum", "cathedral", "shopping center", "city hall"],
          "answer": "shopping center"
        },
        {
          "question": "What is 'stacja kolejowa'?",
          "options": ["bus stop", "tram stop", "airport", "train station"],
          "answer": "train station"
        }
      ]
    },
    {
      "id": "5.2",
      "type": "multiple_choice",
      "title": "Adverbs of place and double negation",
      "questions": [
        {
          "question": "What does 'nigdzie' mean?",
          "options": ["everywhere", "anywhere", "nowhere", "somewhere"],
          "answer": "nowhere"
        },
        {
          "question": "What does 'wszędzie' mean?",
          "options": ["nowhere", "anywhere", "somewhere", "everywhere"],
          "answer": "everywhere"
        },
        {
          "question": "In Polish, double negation is:",
          "options": ["a mistake like in English", "optional", "the correct way", "only used in formal writing"],
          "answer": "the correct way"
        },
        {
          "question": "Which sentence uses double negation correctly?",
          "options": ["Nigdzie mogę tego znaleźć.", "Nigdzie nie mogę tego znaleźć.", "Nie mogę tego znaleźć gdziekolwiek.", "Mogę tego nigdzie znaleźć."],
          "answer": "Nigdzie nie mogę tego znaleźć."
        },
        {
          "question": "What does 'nikt' mean?",
          "options": ["nothing", "never", "none", "nobody"],
          "answer": "nobody"
        }
      ]
    },
    {
      "id": "5.3",
      "type": "multiple_choice",
      "title": "Modal verbs — chcieć, móc, umieć, musieć",
      "questions": [
        {
          "question": "What is the difference between 'móc' and 'umieć'?",
          "options": [
            "No difference",
            "'móc' = permission/ability, 'umieć' = learned skill",
            "'umieć' = permission/ability, 'móc' = learned skill",
            "'móc' = must, 'umieć' = want"
          ],
          "answer": "'móc' = permission/ability, 'umieć' = learned skill"
        },
        {
          "question": "Ariana Grande _______ śpiewać. (has the skill to sing)",
          "options": ["może", "musi", "umie", "chce"],
          "answer": "umie"
        },
        {
          "question": "Nie _______ pani tu parkować. (you are not allowed to park here)",
          "options": ["umie", "chce", "może", "musi"],
          "answer": "może"
        },
        {
          "question": "What is the 'ja' form of 'musieć'?",
          "options": ["muszę", "musisz", "musi", "musimy"],
          "answer": "muszę"
        },
        {
          "question": "What is the 'ty' form of 'chcieć'?",
          "options": ["chcę", "chce", "chcemy", "chcesz"],
          "answer": "chcesz"
        },
        {
          "question": "What is the 'oni/one' form of 'móc'?",
          "options": ["możemy", "mogą", "możecie", "może"],
          "answer": "mogą"
        }
      ]
    },
    {
      "id": "5.4",
