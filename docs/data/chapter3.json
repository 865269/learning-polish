      "id": "3.1",
      "type": "short_answer",
      "title": "Hotel questions (write the question)",
      "questions": [
        {
          "question": "What question would get this answer: 'Niestety, przyjmujemy tylko gotówkę.' (Unfortunately we only accept cash.)",
          "answer": "Czy można tu płacić kartą?",
          "note": "The answer mentions only accepting cash, so the question asks about card payment."
        },
        {
          "question": "What question would get this answer: 'Śniadanie jest płatne dodatkowo.' (Breakfast is extra.)",
          "answer": "Czy cena uwzględnia śniadanie?",
          "note": "The answer is about breakfast pricing, so the question asks if breakfast is included."
        },
        {
          "question": "What question would get this answer: 'Pokój numer 34, do końca korytarza i w lewo.' (Room 34, straight through the corridor and to the left.)",
          "answer": "Jaki jest numer pokoju?",
          "note": "The answer gives a room number, so the question asks for the room number."
        },
        {
          "question": "What question would get this answer: 'Oczywiście, mamy kilka pokoi w tym terminie.' (Of course, we have a few rooms available on this date.)",
          "answer": "Czy macie Państwo wolny pokój w tym terminie?",
          "note": "The answer confirms room availability, so the question asks about availability."
        },
        {
          "question": "What question would get this answer: 'Doba hotelowa kończy się o 11:00.' (The hotel night ends at 11 AM.)",
          "answer": "O której kończy się doba hotelowa?",
